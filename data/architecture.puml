@startuml ClassDiagram

skinparam backgroundColor white
skinparam classBackgroundColor #1e293b
skinparam classBorderColor #38bdf8
skinparam classArrowColor #7dd3fc
skinparam classFontColor #e2e8f0
skinparam linetype ortho

' ========================
' INPUT LAYER
' ========================
package "Input Layer" {
    interface IInputModule
    class CSVInputModule

    IInputModule <|.. CSVInputModule
}

' ========================
' CORE ENGINE
' ========================
package "Core Engine" {

    interface ICoreWorker
    class CoreWorker
    class Aggregator
    class FunctionalCore <<stateless>>

    ICoreWorker <|.. CoreWorker

    CoreWorker --> FunctionalCore
    Aggregator --> FunctionalCore
}

' ========================
' DATA CONTRACTS
' ========================
package "Data Contracts" {
    class RawPacket
    class ProcessedPacket
}

CSVInputModule --> RawPacket
CoreWorker --> RawPacket
CoreWorker --> ProcessedPacket
Aggregator --> ProcessedPacket

' ========================
' OUTPUT LAYER
' ========================
package "Output Layer" {

    interface IOutputModule
    interface ITelemetryObserver

    class Dashboard <<observer, output>>

    IOutputModule <|.. Dashboard
    ITelemetryObserver <|.. Dashboard
}

' ========================
' TELEMETRY
' ========================
package "Telemetry" {
    class PipelineTelemetry

    PipelineTelemetry o-- ITelemetryObserver
}

' ========================
' ORCHESTRATOR
' ========================
package "Main" {
    class Orchestrator
}

Orchestrator --> CSVInputModule
Orchestrator --> CoreWorker
Orchestrator --> Aggregator
Orchestrator --> PipelineTelemetry
Orchestrator --> Dashboard

Dashboard --> PipelineTelemetry

@enduml