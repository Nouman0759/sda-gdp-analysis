@startuml GenericConcurrentPipeline

skinparam backgroundColor white
skinparam sequenceParticipantBackgroundColor white
skinparam sequenceParticipantBorderColor #38bdf8
skinparam sequenceArrowColor #7dd3fc
skinparam sequenceFontColor #e2e8f0
skinparam sequenceGroupBorderColor #7dd3fc
skinparam sequenceGroupFontColor #e2e8f0

participant MAIN
participant INPUT
participant "Raw Queue\n(bounded, backpressure)" as RQ
participant "Core Workers (xN)" as CW
participant "Processed Stream Queue" as IQ
participant AGG
participant "Processed Queue\n(bounded, backpressure)" as PQ
participant TELEMETRY
participant DASH

== Initialization ==
MAIN -> INPUT : start()
MAIN -> CW : start (parallelism from config)
MAIN -> AGG : start()
MAIN -> TELEMETRY : start()
MAIN -> DASH : run()

== Data Stream: Input → Core ==
loop Streaming data
    INPUT -> RQ : put(data_packet)
end

par Core Workers (xN)
    CW -> RQ : get(packet)
    CW -> CW : verify_signature()
    CW -> IQ : put(processed_packet)
end

== Aggregation (Resequencing + Stateful Processing) ==
loop Process packets
    AGG -> IQ : get(packet)
    AGG -> AGG : resequence + compute_running_average()
    AGG -> PQ : put(result)
end

== Output (Visualization) ==
loop Real-time visualization
    DASH -> PQ : consume(result)
    DASH -> DASH : render_visualization(result)
end

== Telemetry (Observer Pattern) ==
loop Periodic monitoring
    TELEMETRY -> RQ : poll queue size
    TELEMETRY -> PQ : poll queue size
    TELEMETRY -> DASH : notify()
end

@enduml